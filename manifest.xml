<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>dd41f735-583f-4690-9ae0-94f1675d9352</Id>
  <Version>1.0.0.4</Version>
  <ProviderName>CyberITEX</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="CTX-Stamp"/>
  <Description DefaultValue="Automatically inserts company signature on new emails."/>

  <IconUrl DefaultValue="https://cyberitex.github.io/CTX-Signature/assets/logo-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://cyberitex.github.io/CTX-Signature/assets/logo-32.png"/>
  <SupportUrl DefaultValue="https://cyberitex.github.io/CTX-Signature"/>

  <AppDomains>
    <AppDomain>https://cyberitex.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <!-- 🔥 IMPORTANT: baseline -->
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <!-- ========================= -->
  <!-- VERSION OVERRIDES 1.0 -->
  <!-- ========================= -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
    xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.8">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>

          <!-- Required for commands -->
          <FunctionFile resid="Commands.Url"/>

          <!-- Button fallback (VERY IMPORTANT) -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="signatureGroup">
                <Label resid="GroupLabel"/>

                <Control xsi:type="Button" id="insertSignatureBtn">
                  <Label resid="InsertLabel"/>
                  <Supertip>
                    <Title resid="InsertLabel"/>
                    <Description resid="InsertTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16"/>
                    <bt:Image size="32" resid="Icon.32"/>
                    <bt:Image size="80" resid="Icon.80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>onNewMessageCompose</FunctionName>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://cyberitex.github.io/CTX-Signature/assets/logo-32.png"/>
        <bt:Image id="Icon.32" DefaultValue="https://cyberitex.github.io/CTX-Signature/assets/logo-32.png"/>
        <bt:Image id="Icon.80" DefaultValue="https://cyberitex.github.io/CTX-Signature/assets/logo-32.png"/>
      </bt:Images>

      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://cyberitex.github.io/CTX-Signature/commands.html"/>
        <bt:Url id="JSRuntime.Url" DefaultValue="https://cyberitex.github.io/CTX-Signature/commands.js"/>
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Signature"/>
        <bt:String id="InsertLabel" DefaultValue="Insert Signature"/>
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="InsertTooltip" DefaultValue="Insert company signature"/>
      </bt:LongStrings>
    </Resources>

    <!-- ========================= -->
    <!-- VERSION OVERRIDES 1.1 -->
    <!-- ========================= -->
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
      xsi:type="VersionOverridesV1_1">

      <!-- 🔥 CRITICAL FIX -->
      <Requirements>
        <bt:Sets DefaultMinVersion="1.12">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">

          <!-- 🔥 Runtime separation -->
          <Runtimes>
            <Runtime resid="JSRuntime.Url" lifetime="short"/>
          </Runtimes>

          <DesktopFormFactor>

            <!-- 🔥 EVENT-BASED ACTIVATION -->
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnNewMessageCompose" FunctionName="onNewMessageCompose"/>
              </LaunchEvents>

              <!-- MUST point to JS -->
              <SourceLocation resid="JSRuntime.Url"/>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Urls>
          <bt:Url id="JSRuntime.Url" DefaultValue="https://cyberitex.github.io/CTX-Signature/commands.js"/>
        </bt:Urls>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>